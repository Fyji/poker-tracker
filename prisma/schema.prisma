generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  gameResults GameResult[]

  @@map("players")
}

model Game {
  id            String         @id @default(cuid())
  pokernowId    String         @unique
  playedAt      DateTime       @default(now())
  createdAt     DateTime       @default(now())
  csvUploaded   Boolean        @default(false)
  totalHands    Int?
  gameResults   GameResult[]
  debts         Debt[]
  logs          GameLog[]
  handSummaries HandSummary[]

  @@map("games")
}

model GameResult {
  id       String @id @default(cuid())
  gameId   String
  playerId String
  buyIn    Float
  net      Float
  rawData  Json?

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
  @@map("game_results")
}

model Debt {
  id        String   @id @default(cuid())
  gameId    String
  fromName  String
  toName    String
  amount    Float
  paid      Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("debts")
}

model GameLog {
  id         String    @id @default(cuid())
  gameId     String
  handNumber Int
  position   String
  playerName String
  action     String
  amount     Float?
  cards      String?
  potSize    Float?
  timestamp  DateTime?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_logs")
}

model HandSummary {
  id          String  @id @default(cuid())
  gameId      String
  handNumber  Int
  winner      String?
  winAmount   Float?
  winHand     String?
  potSize     Float?
  flop        String?
  turn        String?
  river       String?
  duration    Int?
  playerCount Int?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, handNumber])
  @@map("hand_summaries")
}

model Payment {
  id        String   @id @default(cuid())
  debtId    String
  amount    Float
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@map("payments")
}
